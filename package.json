{
  "name": "suitweave",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --pretty false",
    "arch:check": "dependency-cruiser src --config dependency-cruiser.config.cjs",
    "validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm arch:check && pnpm build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "react": "latest",
    "react-dom": "latest",
    "vite": "^7.1.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "dependency-cruiser": "latest",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "prettier": "latest",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "latest"
  }
}
